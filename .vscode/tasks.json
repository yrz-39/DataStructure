{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build cpp",
            "type": "shell",
            "command": "C:/msys64/ucrt64/bin/g++.exe",
            "args": [
                "-g",
                "-std=c++17",
                "-finput-charset=UTF-8",
                "-fexec-charset=GBK",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ],
            "detail": "Build current cpp file"
        },
        {
            "label": "run cpp",
            "type": "shell",
            "dependsOn": "build cpp",
            "dependsOrder": "sequence",
            "command": "cmd",
            "args": [
                "/c",
                "start",
                "\"${fileBasenameNoExtension}\"",
                "cmd",
                "/k",
                "chcp 936>nul && \"${fileDirname}\\${fileBasenameNoExtension}.exe\" && echo. && pause"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build and run current cpp file in external console"
        }
    ]
}
